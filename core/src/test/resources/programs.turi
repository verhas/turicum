-- TEST preprocessorSample


fn adhoc(){ // this will be deleted, it only exists in the preprocessor context
  "huhu "
}
# {|lexes|
["""
    fn adhoc(){ // this will be deleted, it only exists in the preprocessor context
        "huha "
        }
    mut M:str = ""
    fn adhic(){
      "hihi "
    }
    M = M + "hello ";
    M = M + (adhoc() or "none ");
""",..lexes]
}
M = M + adhic() + "hangyavadasz"

