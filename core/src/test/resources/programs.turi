-- TEST try2
// when there is an error, the local variables are not changed
// if there is no error, the local variables are defined in the surrounding context

mut a = 1

try:
    mut [b,c,d] = {
        mut b = 13;
        mut c = 55;
        mut D = 63;
        k = 1/ 0;
        [b,c,D]
    }
catch:;
die "b" when is_defined(b)
die "c" when is_defined(c)
die "d" when is_defined(d)
die "D" when is_defined(D)

try:
    mut [b,c,d] = {
        mut b = 13;
        mut c = 55;
        mut D = 63;
        [b,c,D]
    }
catch:;
die "!b" when ! is_defined(b)
die "!c" when ! is_defined(c)
die "!d" when ! is_defined(d)
// D is still not defined
die "D" when is_defined(D)

