fn fun(@a:bool, [rest],{meta},^closurea){
  if a :
    closurea(a , rest[0] , rest[1] , meta.b)
  else:
    ""+rest[0] + rest[1] + meta.b
}
mut x = fun(a=true,3, 45, b="ka"){|a,b,c,d| ""+ d + c + b }
mut klos = {|a,b,c,d| ""+ d + c + b }
mut y = fun(a=false,3, 45, b="ka", klos)
x + y
