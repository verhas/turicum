-- TEST reclosingClosure
mut MESSAGE = ""
mut z = 55;
mut y = 77;
mut x = {|| MESSAGE = MESSAGE + z + " "
        z = y;
    };
x(); // 55, z <- 77
{
  mut z = 63;
  x(); // 77
  MESSAGE = MESSAGE + z + " " // 77
  y = 99;
  reclose(x)(); // 63
  MESSAGE = MESSAGE + z + " " // 99
}
MESSAGE = MESSAGE + z + " ";
MESSAGE = MESSAGE[0…-1]

