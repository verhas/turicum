-- TEST streaming


fn gen_1_to_10 {
    for i=1 ; i <= 10 ; i = i + 1:
        yield i;
    return 1000
}

mut st = async gen_1_to_10();
//println( st );
while st.has_next() :
    st.next();
await[10000] st

