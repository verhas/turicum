-- TEST multi_let1
// a simple test that assigns values to listed variables
let [a,b,c] = [1,2,3]
die when a != 1
die when b != 2
die when c != 3
try {
    a = 3
}catch e: none;
die "reassigned" when a == 3

-- TEST multi_let2
// a simple test that assigns values to field-named variables
let {a,b,c} = { c: 3, "a":1, b:2}
die when a != 1
die when b != 2
die when c != 3
try {
    a = 3
}catch e: none;
die "reassigned" when a == 3

-- TEST multi_let3
// a simple test that assigns values to field-specified variables
let {ac->a, bc->b, cc->c} = { cc: 3, "ac":1, bc:2}
die when a != 1
die when b != 2
die when c != 3
try {
    a = 3
}catch e: none
die "reassigned" when a == 3

-- TEST multi_let4
// assign value to left value
let a = {}
mut { ac->a.a, bc->b, cc->c } = { cc: 3, "ac":1, bc:2}
die when a.a != 1
die when b != 2
die when c != 3
a.a = 3
die "reassigned" when a.a != 3

