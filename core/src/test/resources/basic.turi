sys_import turi.basic
#basic

fn LIST(lexes){
    try {
        for each lex in lexes list {
            if lex.atLineStart {
                println "";
            }
            print lex.text, " "
            lex
        }
        }finally {
        println;
    }
}

// #LIST // uncomment at the start of the line to print out the program

LET A = 12
LET B = 14
IF A+B == 26 THEN
PRINT "Yes, it works."
ELSE
PRINT "No, it does not work, it is ",(A+B)
ENDIF

LET I = 0
WHILE I < 10 DO
PRINT I
I = I+1
WEND

