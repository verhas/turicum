sys_import turi.basic
#basic

LET A = 12
LET B = 14
IF A+B == 26 THEN
PRINT "Yes, it works."
ELSE
PRINT "No, it does not work, it is ",(A+B)
ENDIF

LET I = 0
WHILE I < 10 DO
PRINT I
I = I+1
WEND

REM line numbers are accepted and ignored by the structured preprocessor
100 FOR J = 1 TO 5 STEP 2
PRINT "FOR", J
NEXT J

LET GRADE = 2
IF GRADE == 1 THEN
PRINT "one"
ELSE
PRINT "not one"
ENDIF

LET R = 0
REPEAT
R = R + 1
PRINT "REPEAT", R
UNTIL R == 3

LET D = 0
DO
D = D + 1
PRINT "DO", D
LOOP UNTIL D == 2

IF D == 2 THEN PRINT "inline IF works"
