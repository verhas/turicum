class Resource {
    
    fn k(){
        println "haha"
    }
    
}


with Resource {
    k()
}


class ResourceManager {
    fn entry {
        println "creating glass"
        cls
    }
    fn exit( e ){
        if e != none {
            println e
            return true
            } else{
            println $"m is ${m}"
        }
        false
    }
    mut m:int|none = none;
    fn get {
        cls.m
    }
}


with ResourceManager as g {
    println g.get()
    g.m = 13;
    die "yayyy"
}

