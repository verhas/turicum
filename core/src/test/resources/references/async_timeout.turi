let z=async[ time= 1 / 20] {
    while{
        //burn some CPU doing nothing
    }
}

// sleep 100ms, should be enough to timeout
sleep 0.1

println "All three results should be true"
println $"  z is done ${z.is_done()}"
println $"  z is err ${z.is_err()}"
println $"  z is timeout ${z.is_timeout()}"
