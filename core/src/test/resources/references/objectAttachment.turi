class B {
    fn a {
        if is_defined(this) :
            println $"hello ${this}, ${cls}  ${it}";
        else :
            println $"hello ${none}, ${cls}  ${it}";
    }
}
let b = B()
let z = [ 1,2,3 ]
let k = [ ..z with b];
let h = [ ..z with B];
b.Kukk = 2;
k.a();
println k.Kukk
println "Now with h"
h.a()
println h.Kukk

let w = k[1..3]
w.a()
